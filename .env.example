# Runtime
APP_MODE=test
LOG_LEVEL=INFO

# Camera input: snapshot or rtsp
CAMERA_SOURCE=snapshot
CAMERA_SNAPSHOT_URL=https://192.168.2.44/cgi-bin/api.cgi?cmd=Snap&channel=0&rs=garbagevision
CAMERA_RTSP_URL=rtsp://192.168.2.44:554/h264Preview_01_main
CAMERA_USERNAME=admin
CAMERA_PASSWORD=

# Set false for local Reolink cameras that redirect to self-signed HTTPS.
CAMERA_VERIFY_TLS=false

# Test inputs
IMAGE_DIR=samples/images
VIDEO_FILE=samples/video/test.mp4

# Production polling
POLL_SECONDS=60

# Baseline detector tuning
DETECTION_THRESHOLD=0.02
MIN_CHANGED_AREA=4000
DETECTION_ROI=0,760,1900,856
OUTPUT_DIR=data/detections
BASELINE_IMAGE=data/baseline/clean.jpg
PREVIEW_DIR=data/previews

# Notifications
NOTIFY_ENABLED=false
DRY_RUN_NOTIFICATIONS=true
WEBHOOK_URL=

# Optional YOLO verification after ROI change detection.
# Install with: uv sync --extra yolo
OBJECT_DETECTION_ENABLED=true
OBJECT_VERIFY_REQUIRED=false
OBJECT_MODEL=yolov8n.pt
OBJECT_CONFIDENCE=0.35
OBJECT_IMAGE_SIZE=1280
OBJECT_CLASSES=afval,vaat,bottle,cup,bowl,backpack,handbag,suitcase,book,cell phone
